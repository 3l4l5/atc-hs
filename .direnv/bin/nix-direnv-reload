#!/usr/bin/env bash
set -e
if [[ ! -d "/Users/ryusei/src/github.com/3l4l5/atc-hs" ]]; then
  echo "Cannot find source directory; Did you move it?"
  echo "(Looking for "/Users/ryusei/src/github.com/3l4l5/atc-hs")"
  echo 'Cannot force reload with this script - use "direnv reload" manually and then try again'
  exit 1
fi

# rebuild the cache forcefully
_nix_direnv_force_reload=1 direnv exec "/Users/ryusei/src/github.com/3l4l5/atc-hs" true

# Update the mtime for .envrc.
# This will cause direnv to reload again - but without re-building.
touch "/Users/ryusei/src/github.com/3l4l5/atc-hs/.envrc"

# Also update the timestamp of whatever profile_rc we have.
# This makes sure that we know we are up to date.
touch -r "/Users/ryusei/src/github.com/3l4l5/atc-hs/.envrc" "/Users/ryusei/src/github.com/3l4l5/atc-hs/.direnv"/*.rc
